(defn test-assert-eq-integers ()
  (assert-eq 1 1))

(defn test-assert-eq-strings ()
  (assert-eq "hello" "hello"))

(defn test-assert-eq-lists ()
  (assert-eq (list 1 2 3) (list 1 2 3)))

(defn test-assert-ne-different-values ()
  (assert-ne 1 2))

(defn test-assert-true-truthy ()
  (do
    (assert-true true)
    (assert-true 1)
    (assert-true "nonempty")))

(defn test-assert-false-falsy ()
  (do
    (assert-false false)
    (assert-false 0)))

(defn test-pipeline-with-assertions ()
  (def result (-> (list 1 2 3)
                     (map (fn (n) (* n 2)))
                     (filter (fn (n) (> n 2)))))
  (assert-eq result (list 4 6)))
